#!/usr/bin/env bash
# =============================================================================
#  TURBO RECORDER — state-of-the-art Linux screen & audio recorder (X11)
#
#  Auto-detects, with sane overrides via environment variables:
#    * CPU vendor            (Intel / AMD)
#    * GPU vendor + best HW encoder
#        NVIDIA NVENC  >  Intel/AMD VAAPI  >  software libx264
#    * primary screen resolution (no upscaling — captures native size)
#    * default microphone and default system-audio (monitor) source
#    * which mic channel carries audio, then duplicates it to stereo
#
#  Then it builds a quality-first FFmpeg pipeline.
#
#  For Windows/macOS or a GUI, use the cross-platform companion:  turborec.py
# =============================================================================
set -euo pipefail
IFS=$'\n\t'

# ---------------------------
# Configurable defaults (override via environment)
# ---------------------------
VID_DIR="${VID_DIR:-$HOME/Videos}"
AUD_DIR="${AUD_DIR:-$HOME/Audio}"
REQUEST_RECORDING_RES="${REQUEST_RECORDING_RES:-}"   # empty => use full screen
FPS="${FPS:-60}"
QUALITY="${QUALITY:-best}"                            # best|high|balanced|compact
CODEC="${CODEC:-h264}"                                # h264|hevc
AUDIO_RATE="${AUDIO_RATE:-48000}"
AUDIO_CODEC="${AUDIO_CODEC:-flac}"                    # flac|aac|opus
FORCE_SOFTWARE="${FORCE_SOFTWARE:-0}"
VAAPI_DEVICE="${VAAPI_DEVICE:-}"                       # auto-detected if empty

# Audio sources — auto-detected if left empty
MONITOR_SOURCE="${MONITOR_SOURCE:-}"
MIC_SOURCE="${MIC_SOURCE:-}"

# ---------------------------
# Helpers
# ---------------------------
die(){ printf '%s\n' "$*" >&2; exit 1; }
have(){ command -v "$1" >/dev/null 2>&1; }
ensure_dir(){ local d="$1"; [ -e "$d" ] && [ ! -d "$d" ] && die "Not a directory: $d"; mkdir -p "$d"; }
timestamp(){ date +"%Y-%m-%d_%H-%M-%S"; }

# ---------------------------
# CPU detection (informational)
# ---------------------------
detect_cpu(){
  CPU_VENDOR="unknown"
  if [ -r /proc/cpuinfo ]; then
    if grep -qi "GenuineIntel" /proc/cpuinfo; then CPU_VENDOR="intel"
    elif grep -qi "AuthenticAMD" /proc/cpuinfo; then CPU_VENDOR="amd"; fi
  fi
}

# ---------------------------
# GPU + encoder detection
#   Sets: GPU_VENDOR, ENC_KIND, VENCODER, VENC_ARGS[], VFILTER, PRE_INPUT[]
# ---------------------------
detect_first_render_node(){
  local n
  for n in /dev/dri/renderD*; do
    [ -e "$n" ] && { printf '%s' "$n"; return; }
  done
  printf ''
}

ffmpeg_has_encoder(){ ffmpeg -hide_banner -encoders 2>/dev/null | awk '{print $2}' | grep -qx "$1"; }

detect_gpu(){
  GPU_VENDOR="unknown"
  if have nvidia-smi && nvidia-smi -L >/dev/null 2>&1; then
    GPU_VENDOR="nvidia"
  else
    local pci; pci="$(lspci 2>/dev/null | grep -iE 'vga|3d|display' || true)"
    case "${pci,,}" in
      *nvidia*) GPU_VENDOR="nvidia" ;;
      *"advanced micro devices"*|*"amd/ati"*|*radeon*) GPU_VENDOR="amd" ;;
      *intel*) GPU_VENDOR="intel" ;;
    esac
  fi
  [ -z "$VAAPI_DEVICE" ] && VAAPI_DEVICE="$(detect_first_render_node)"
}

# Map QUALITY preset -> a single index 0..3
quality_index(){
  case "$QUALITY" in
    best) printf '0' ;; high) printf '1' ;;
    balanced) printf '2' ;; compact) printf '3' ;;
    *) printf '0' ;;
  esac
}

pick_from(){ # pick_from idx a b c d  -> echoes the (idx)-th value (0-based)
  local idx="$1"; shift; local arr=("$@"); printf '%s' "${arr[$idx]}"; }

# Decide encoder and build the encode argument array
select_encoder(){
  local codec="$CODEC" qi; qi="$(quality_index)"
  PRE_INPUT=(); VENC_ARGS=(); VFILTER=""

  local want_nvenc want_vaapi want_sw
  want_nvenc="${codec}_nvenc"
  want_vaapi="${codec}_vaapi"
  want_sw="libx264"; [ "$codec" = "hevc" ] && want_sw="libx265"

  if [ "$FORCE_SOFTWARE" = "1" ]; then
    ENC_KIND="software"; VENCODER="$want_sw"
  elif [ "$GPU_VENDOR" = "nvidia" ] && ffmpeg_has_encoder "$want_nvenc"; then
    ENC_KIND="nvenc"; VENCODER="$want_nvenc"
  elif [ -n "$VAAPI_DEVICE" ] && ffmpeg_has_encoder "$want_vaapi"; then
    ENC_KIND="vaapi"; VENCODER="$want_vaapi"
  elif ffmpeg_has_encoder "$want_sw"; then
    ENC_KIND="software"; VENCODER="$want_sw"
  else
    die "No usable $codec encoder found in your FFmpeg build."
  fi

  case "$ENC_KIND" in
    nvenc)
      local cq; cq="$(pick_from "$qi" 16 19 23 28)"
      VENC_ARGS=( -c:v "$VENCODER" -preset p7 -tune hq -rc vbr -cq "$cq"
                  -b:v 0 -spatial-aq 1 -temporal-aq 1 -rc-lookahead 32 -bf 3 )
      [ "$codec" = "h264" ] && VENC_ARGS+=( -profile:v high )
      VFILTER="format=yuv420p"
      ;;
    vaapi)
      local qp; qp="$(pick_from "$qi" 18 22 26 30)"
      PRE_INPUT=( -vaapi_device "$VAAPI_DEVICE" )
      VENC_ARGS=( -c:v "$VENCODER" -qp "$qp" -compression_level 1 )
      [ "$codec" = "h264" ] && VENC_ARGS+=( -profile:v high )
      VFILTER="format=nv12,hwupload"
      ;;
    software)
      local crf; crf="$(pick_from "$qi" 16 20 24 28)"
      VENC_ARGS=( -c:v "$VENCODER" -preset slow -crf "$crf" )
      [ "$VENCODER" = "libx264" ] && VENC_ARGS+=( -profile:v high -tune film )
      VFILTER="format=yuv420p"
      ;;
  esac
  VENC_ARGS+=( -color_primaries bt709 -color_trc bt709 -colorspace bt709 )
}

# Audio encode args -> populates the AUDIO_ARGS array
build_audio_args(){
  case "$AUDIO_CODEC" in
    opus) AUDIO_ARGS=( -c:a libopus -b:a 256k -ar 48000 -ac 2 ) ;;
    aac)  AUDIO_ARGS=( -c:a aac -b:a 320k -ar "$AUDIO_RATE" -ac 2 ) ;;
    *)    AUDIO_ARGS=( -c:a flac -ar "$AUDIO_RATE" -ac 2 ) ;;
  esac
}

# ---------------------------
# Screen size (no upscaling)
# ---------------------------
detect_screen_size(){
  if have xdpyinfo; then
    xdpyinfo 2>/dev/null | awk '/dimensions:/ {print $2; exit}'; return
  fi
  if have xrandr; then
    xrandr --query 2>/dev/null | awk '/ connected/ { split($4,a,/[+x]/); if (a[1] ~ /^[0-9]+$/) { print a[1]"x"a[2]; exit } }'
    return
  fi
  printf ''
}

min_of(){ [ "$1" -le "$2" ] && printf '%d' "$1" || printf '%d' "$2"; }

compute_capture_res(){
  local screen sw sh rw rh
  screen="$(detect_screen_size || true)"
  if [ -z "$REQUEST_RECORDING_RES" ]; then
    CAPTURE_RES="${screen:-1920x1080}"; return
  fi
  if [ -z "$screen" ]; then CAPTURE_RES="$REQUEST_RECORDING_RES"; return; fi
  sw="${screen%x*}"; sh="${screen#*x}"
  rw="${REQUEST_RECORDING_RES%x*}"; rh="${REQUEST_RECORDING_RES#*x}"
  CAPTURE_RES="$(min_of "$rw" "$sw")x$(min_of "$rh" "$sh")"
}

build_x11_args(){
  local display="${DISPLAY:-:0.0}"
  X11_ARGS=( -f x11grab -framerate "$FPS" -thread_queue_size 1024 -video_size "$CAPTURE_RES" -i "${display}+0,0" )
}

# ---------------------------
# Pulse / PipeWire source auto-detection
# ---------------------------
autodetect_sources(){
  have pactl || die "pactl not found (need PulseAudio or PipeWire)."
  if [ -z "$MONITOR_SOURCE" ]; then
    local sink; sink="$(pactl get-default-sink 2>/dev/null || true)"
    if [ -n "$sink" ] && check_pulse_source "${sink}.monitor"; then
      MONITOR_SOURCE="${sink}.monitor"
    else
      MONITOR_SOURCE="$(pactl list short sources 2>/dev/null | awk -F'\t' '$2 ~ /\.monitor$/ {print $2; exit}')"
    fi
  fi
  if [ -z "$MIC_SOURCE" ]; then
    local src; src="$(pactl get-default-source 2>/dev/null || true)"
    if [ -n "$src" ] && [[ "$src" != *.monitor ]] && check_pulse_source "$src"; then
      MIC_SOURCE="$src"
    else
      MIC_SOURCE="$(pactl list short sources 2>/dev/null | awk -F'\t' '$2 !~ /\.monitor$/ {print $2; exit}')"
    fi
  fi
}

check_pulse_source(){
  pactl list short sources 2>/dev/null | awk -F'\t' -v m="$1" '$2==m {found=1} END{exit !found}'
}

# ---------------------------
# Detect which mic channel carries audio -> PAN to stereo
# ---------------------------
detect_mic_channel(){
  local sname="$1" in_section=0 vol_line=""
  PAN="stereo|c0=c1|c1=c1"   # default: duplicate RIGHT
  [ -z "$sname" ] && return 0
  while IFS= read -r line; do
    if [[ "$line" =~ ^Name:[[:space:]]*${sname}$ ]]; then in_section=1; continue; fi
    if [ $in_section -eq 1 ]; then
      [[ "$line" =~ ^[[:space:]]*Volume: ]] && { vol_line="$line"; break; }
      [[ "$line" =~ ^Name: ]] && break
    fi
  done < <(pactl list sources 2>/dev/null)
  [ -z "$vol_line" ] && return 0
  local pcts left right
  pcts=$(printf '%s' "$vol_line" | sed 's/,/ /g' | grep -o '[0-9]\+%' | tr -d '%') || true
  left="$(printf '%s' "$pcts"  | awk '{print $1+0}' 2>/dev/null || printf '0')"
  right="$(printf '%s' "$pcts" | awk '{print $2+0}' 2>/dev/null || printf '0')"
  if [ "${left:-0}" -eq 0 ] && [ "${right:-0}" -gt 0 ]; then PAN="stereo|c0=c1|c1=c1"
  elif [ "${right:-0}" -eq 0 ] && [ "${left:-0}" -gt 0 ]; then PAN="stereo|c0=c0|c1=c0"; fi
}

# ---------------------------
# Recording functions
# ---------------------------
audio_internal_only(){
  ensure_dir "$AUD_DIR"; local out; out="${AUD_DIR}/audio_internal_$(timestamp).${AUDIO_EXT}"
  ffmpeg -y -hide_banner -loglevel info -stats \
    -f pulse -thread_queue_size 1024 -i "$MONITOR_SOURCE" \
    -af "${ARESAMPLE},pan=${PAN}" "${AUDIO_ARGS[@]}" "$out"
}

audio_microphone_only(){
  ensure_dir "$AUD_DIR"; local out; out="${AUD_DIR}/audio_mic_$(timestamp).${AUDIO_EXT}"
  ffmpeg -y -hide_banner -loglevel info -stats \
    -f pulse -thread_queue_size 1024 -i "$MIC_SOURCE" \
    -af "${ARESAMPLE},pan=${PAN}" "${AUDIO_ARGS[@]}" "$out"
}

audio_internal_and_mic(){
  ensure_dir "$AUD_DIR"; local out; out="${AUD_DIR}/audio_mixed_$(timestamp).${AUDIO_EXT}"
  ffmpeg -y -hide_banner -loglevel info -stats \
    -f pulse -thread_queue_size 1024 -i "$MONITOR_SOURCE" \
    -f pulse -thread_queue_size 1024 -i "$MIC_SOURCE" \
    -filter_complex \
      "[0:a]${ARESAMPLE},pan=${PAN}[a0];[1:a]${ARESAMPLE},pan=${PAN}[a1];[a0][a1]amix=inputs=2:duration=longest:dropout_transition=2:normalize=0,${ARESAMPLE}[a]" \
    -map "[a]" "${AUDIO_ARGS[@]}" "$out"
}

video_without_audio(){
  ensure_dir "$VID_DIR"; local out; out="${VID_DIR}/video_noaudio_$(timestamp).mkv"
  ffmpeg -y -hide_banner -loglevel info -stats \
    "${PRE_INPUT[@]}" "${X11_ARGS[@]}" \
    -vf "$VFILTER" "${VENC_ARGS[@]}" "$out"
}

video_with_internal_audio(){
  ensure_dir "$VID_DIR"; local out; out="${VID_DIR}/video_internal_$(timestamp).mkv"
  ffmpeg -y -hide_banner -loglevel info -stats \
    "${PRE_INPUT[@]}" "${X11_ARGS[@]}" \
    -f pulse -thread_queue_size 1024 -i "$MONITOR_SOURCE" \
    -filter_complex "[0:v]${VFILTER}[v];[1:a]${ARESAMPLE},pan=${PAN}[a]" \
    -map "[v]" -map "[a]" "${VENC_ARGS[@]}" "${AUDIO_ARGS[@]}" "$out"
}

video_with_microphone(){
  ensure_dir "$VID_DIR"; local out; out="${VID_DIR}/video_mic_$(timestamp).mkv"
  ffmpeg -y -hide_banner -loglevel info -stats \
    "${PRE_INPUT[@]}" "${X11_ARGS[@]}" \
    -f pulse -thread_queue_size 1024 -i "$MIC_SOURCE" \
    -filter_complex "[0:v]${VFILTER}[v];[1:a]${ARESAMPLE},pan=${PAN}[a]" \
    -map "[v]" -map "[a]" "${VENC_ARGS[@]}" "${AUDIO_ARGS[@]}" "$out"
}

video_with_both(){
  ensure_dir "$VID_DIR"; local out; out="${VID_DIR}/video_both_$(timestamp).mkv"
  ffmpeg -y -hide_banner -loglevel info -stats \
    "${PRE_INPUT[@]}" "${X11_ARGS[@]}" \
    -f pulse -thread_queue_size 1024 -i "$MONITOR_SOURCE" \
    -f pulse -thread_queue_size 1024 -i "$MIC_SOURCE" \
    -filter_complex \
      "[0:v]${VFILTER}[v];[1:a]${ARESAMPLE},pan=${PAN}[a1];[2:a]${ARESAMPLE},pan=${PAN}[a2];[a1][a2]amix=inputs=2:duration=longest:dropout_transition=2:normalize=0,${ARESAMPLE}[a]" \
    -map "[v]" -map "[a]" "${VENC_ARGS[@]}" "${AUDIO_ARGS[@]}" "$out"
}

# ---------------------------
# CLI
# ---------------------------
print_help(){
  cat <<EOF
Turbo Recorder — state-of-the-art Linux screen & audio recorder

Usage: $0 [options]
  -m MODE   audio_internal|audio_mic|audio_both|video_noaudio|video_internal|video_mic|video_both
  -o DIR    output directory (sets both video and audio dirs)
  -s WxH    capture size (default: full screen, no upscaling)
  -f FPS    frames per second (default: ${FPS})
  -Q PRESET quality: best|high|balanced|compact (default: ${QUALITY})
  -C CODEC  video codec: h264|hevc (default: ${CODEC})
  -a RATE   audio sample rate (default: ${AUDIO_RATE})
  -A CODEC  audio codec: flac|aac|opus (default: ${AUDIO_CODEC})
  -H DEV    VAAPI device (default: auto)
  -S        force software (CPU) encoding
  -h        this help

Environment overrides: MONITOR_SOURCE, MIC_SOURCE, GPU/CPU auto-detected.
EOF
}

MODE=""
while getopts ":m:o:s:f:Q:C:a:A:H:Sh" opt; do
  case "$opt" in
    m) MODE="$OPTARG" ;;
    o) VID_DIR="$OPTARG"; AUD_DIR="$OPTARG" ;;
    s) REQUEST_RECORDING_RES="$OPTARG" ;;
    f) FPS="$OPTARG" ;;
    Q) QUALITY="$OPTARG" ;;
    C) CODEC="$OPTARG" ;;
    a) AUDIO_RATE="$OPTARG" ;;
    A) AUDIO_CODEC="$OPTARG" ;;
    H) VAAPI_DEVICE="$OPTARG" ;;
    S) FORCE_SOFTWARE=1 ;;
    h) print_help; exit 0 ;;
    \?) die "Invalid option: -$OPTARG" ;;
    :) die "Option -$OPTARG requires an argument." ;;
  esac
done

have ffmpeg || die "ffmpeg not found on PATH."

# Audio container extension
case "$AUDIO_CODEC" in
  flac) AUDIO_EXT="flac" ;; opus) AUDIO_EXT="opus" ;; aac) AUDIO_EXT="m4a" ;; *) AUDIO_EXT="flac" ;;
esac

# High-quality resampler chain (computed after option parsing)
ARESAMPLE="aresample=${AUDIO_RATE}:resampler=soxr"

detect_cpu
detect_gpu
select_encoder
build_audio_args
compute_capture_res
build_x11_args
autodetect_sources
detect_mic_channel "$MIC_SOURCE"

printf '%s\n' \
  "Turbo Recorder — CPU:${CPU_VENDOR} GPU:${GPU_VENDOR} encoder:${VENCODER} (${ENC_KIND}, ${QUALITY})" \
  "Capture: ${CAPTURE_RES} @ ${FPS}fps  (no upscaling)" \
  "Monitor: ${MONITOR_SOURCE:-<none>}" \
  "Mic:     ${MIC_SOURCE:-<none>}  PAN:${PAN}" >&2

if [ -z "${MODE:-}" ]; then
  echo "1) audio internal  2) mic only  3) audio both  4) video no audio" >&2
  echo "5) video internal  6) video mic 7) video both  8) quit" >&2
  printf "Choice [1-8]: " >&2; read -r CHOICE
else
  case "$MODE" in
    audio_internal) CHOICE=1 ;; audio_mic) CHOICE=2 ;; audio_both) CHOICE=3 ;;
    video_noaudio)  CHOICE=4 ;; video_internal) CHOICE=5 ;; video_mic) CHOICE=6 ;;
    video_both)     CHOICE=7 ;; *) CHOICE=8 ;;
  esac
fi

case "$CHOICE" in
  1) audio_internal_only ;;
  2) audio_microphone_only ;;
  3) audio_internal_and_mic ;;
  4) video_without_audio ;;
  5) video_with_internal_audio ;;
  6) video_with_microphone ;;
  7) video_with_both ;;
  8) echo "Bye" >&2; exit 0 ;;
  *) die "Invalid choice" ;;
esac
